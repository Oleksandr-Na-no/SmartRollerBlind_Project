<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Device_Activity">

    <View
        android:id="@+id/view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/IC"
        android:layout_marginTop="@dimen/IT"
        android:layout_marginEnd="@dimen/IC"
        style="@style/Block"
        app:layout_constraintDimensionRatio="5:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        style="@style/Back"
        android:onClick="Clic3"
        android:id="@+id/imageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        app:layout_constraintBottom_toBottomOf="@+id/view"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="@+id/view"
        app:layout_constraintTop_toTopOf="@+id/view" />

    <EditText
        style="@style/Text"
        android:imeOptions="actionDone"
        android:id="@+id/name_edit"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:elevation="5dp"
        android:gravity="center_vertical"
        android:inputType="textCapWords"
        android:selectAllOnFocus="true"
        android:singleLine="true"
        android:text="@string/Name"
        app:layout_constraintBottom_toBottomOf="@+id/view"
        app:layout_constraintEnd_toStartOf="@+id/imageView2"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:layout_constraintTop_toTopOf="@+id/view"
        app:layout_constraintVertical_bias="0.0" />

    <ImageView
        style="@style/Icon"
        android:id="@+id/imageView2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="5dp"
        android:layout_marginBottom="10dp"
        android:onClick="ClicChare"
        app:layout_constraintBottom_toBottomOf="@+id/view"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="@+id/view"
        app:layout_constraintTop_toTopOf="@+id/view"
        app:srcCompat="@drawable/ic_baseline_mobile_screen_share_24" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view"
        app:layout_constraintVertical_bias="0.0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.63" />

            <View
                android:id="@+id/view5"
                style="@style/Block"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="@dimen/IC"
                app:layout_constraintBottom_toBottomOf="@+id/button2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="@+id/line"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="-80dp"
                android:layout_marginEnd="-80dp"
                android:elevation="5dp"
                android:max="10"
                android:maxHeight="20dp"
                android:minHeight="20dp"
                android:progressDrawable="@drawable/seekbar_style"
                android:rotation="90"
                android:splitTrack="false"
                android:thumb="@drawable/custom_thumb"
                app:layout_constraintBottom_toBottomOf="@+id/button2"
                app:layout_constraintEnd_toEndOf="@+id/view5"
                app:layout_constraintStart_toStartOf="@+id/view5"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0" />


            <View
                android:id="@+id/button2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/IC"
                android:layout_marginEnd="@dimen/IC"
                android:background="@drawable/blok_2"
                android:elevation="5dp"
                android:onClick="Click"
                app:layout_constraintDimensionRatio="3:4"
                app:layout_constraintEnd_toStartOf="@+id/line"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/ellipse_1"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:background="@drawable/ellipse_1"
                android:elevation="10dp"
                android:onClick="Click"
                app:layout_constraintBottom_toBottomOf="@+id/button2"
                app:layout_constraintEnd_toEndOf="@+id/button2"
                app:layout_constraintStart_toStartOf="@+id/button2"
                app:layout_constraintTop_toTopOf="@+id/button2"
                tools:ignore="MissingConstraints" />

            <View
                android:id="@+id/rectangle_2"
                android:layout_width="50dp"
                android:layout_height="116dp"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:layout_marginBottom="32dp"
                android:background="@drawable/rectangle_2"
                android:elevation="10dp"
                android:onClick="Click"
                app:layout_constraintBottom_toBottomOf="@+id/ellipse_1"
                app:layout_constraintEnd_toEndOf="@+id/ellipse_1"
                app:layout_constraintStart_toStartOf="@+id/ellipse_1" />

            <View
                android:id="@+id/rectangle_3"
                android:layout_width="30dp"
                android:layout_height="89dp"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:background="@drawable/rectangle_3"
                android:elevation="10dp"
                android:onClick="Click"
                app:layout_constraintBottom_toBottomOf="@+id/rectangle_2"
                app:layout_constraintEnd_toEndOf="@+id/rectangle_2"
                app:layout_constraintStart_toStartOf="@+id/rectangle_2"
                app:layout_constraintTop_toTopOf="@+id/rectangle_2" />

            <Button
                android:id="@+id/view12"
                style="@style/Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/IC"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/IC"
                android:onClick="Clic4"
                android:text="@string/Settings"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view2" />

            <View
                android:id="@+id/view2"
                style="@style/Block"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/IC"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="@dimen/IC"
                android:layout_marginBottom="-10dp"
                app:layout_constraintBottom_toBottomOf="@+id/edit_sensor"
                app:layout_constraintDimensionRatio=""
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view11" />

            <com.rm.rmswitch.RMSwitch
                android:id="@+id/switch1"
                style="@style/Switch"
                android:layout_width="0dp"
                android:layout_height="0dp"

                android:layout_marginStart="10dp"

                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintEnd_toEndOf="@+id/view2"
                app:layout_constraintStart_toStartOf="@+id/line"
                app:layout_constraintTop_toBottomOf="@+id/view11" />

            <!--            <androidx.appcompat.widget.SwitchCompat-->
            <!--                android:id="@+id/switchCompat"-->
            <!--                android:layout_width="wrap_content"-->
            <!--                android:layout_height="0dp"-->
            <!--                android:layout_marginTop="10dp"-->
            <!--                android:layout_marginEnd="48dp"-->
            <!--                android:layout_marginBottom="10dp"-->
            <!--                android:checked="false"-->
            <!--                android:scaleX="2"-->
            <!--                android:scaleY="2"-->
            <!--                android:text=""-->
            <!--                android:thumb="@drawable/thumb"-->
            <!--                app:layout_constraintBottom_toBottomOf="@+id/view2"-->
            <!--                app:layout_constraintEnd_toEndOf="parent"-->
            <!--                app:layout_constraintTop_toTopOf="@+id/view2"-->
            <!--                app:layout_constraintVertical_bias="0.0"-->
            <!--                app:track="@drawable/track" />-->


            <Button
                android:id="@+id/view6"
                style="@style/Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/IC"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/IC"
                android:backgroundTint="?colorOnSecondary"
                android:onClick="Clic1"
                android:text="@string/Delete"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view12" />

            <TextView

                android:id="@+id/sensor"
                style="@style/Text"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="5dp"
                android:autoSizeTextType="uniform"
                android:gravity="center_vertical"
                android:text="Автоматично включатись"
                android:maxLines="1"
                app:layout_constraintBottom_toBottomOf="@+id/switch1"
                app:layout_constraintEnd_toStartOf="@+id/line"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/switch1" />

            <TextView
                android:id="@+id/sensor2"
                style="@style/Text"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="5dp"
                android:gravity="center_vertical"
                android:text="Освітлення зараз"
                app:layout_constraintBottom_toBottomOf="@+id/sensor_text"
                app:layout_constraintEnd_toStartOf="@+id/line"
                app:layout_constraintStart_toStartOf="@+id/sensor"
                app:layout_constraintTop_toBottomOf="@+id/sensor" />

            <TextView
                android:id="@+id/sensor3"
                style="@style/Text"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="5dp"
                android:gravity="center_vertical"
                android:text="Включаєтьс при"
                app:layout_constraintBottom_toBottomOf="@+id/edit_sensor"
                app:layout_constraintEnd_toStartOf="@+id/line"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="@+id/sensor2"
                app:layout_constraintTop_toBottomOf="@+id/sensor2"
                app:layout_constraintVertical_bias="1.0" />

            <EditText
                android:id="@+id/sensor_text"
                style="@style/Edit_Text"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/blok_4"
                android:focusable="false"
                android:gravity="center"
                android:hint="none"
                android:inputType="none"
                android:paddingLeft="10dp"
                android:selectAllOnFocus="false"
                app:layout_constraintDimensionRatio="2:1"
                app:layout_constraintEnd_toEndOf="@+id/switch1"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/switch1"
                app:layout_constraintTop_toBottomOf="@+id/sensor" />

            <EditText
                android:id="@+id/edit_sensor"
                style="@style/Edit_Text"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/blok_4"
                android:gravity="center"
                android:hint="0-1000"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:paddingLeft="10dp"
                app:layout_constraintDimensionRatio="2:1"
                app:layout_constraintEnd_toEndOf="@+id/switch1"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/switch1"
                app:layout_constraintTop_toBottomOf="@+id/sensor_text" />

            <Button
                android:id="@+id/view11"
                style="@style/Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/IC"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/IC"
                android:onClick="Clic_Alarm"
                android:text="@string/Alarms"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/button2" />


            <!--            <View-->
            <!--                android:id="@+id/view10"-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="1000dp"-->
            <!--                android:layout_marginTop="10dp"-->
            <!--                style="@style/Block"-->
            <!--                app:layout_constraintEnd_toEndOf="parent"-->
            <!--                app:layout_constraintStart_toStartOf="parent"-->
            <!--                app:layout_constraintTop_toBottomOf="@+id/view6" />-->


        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>